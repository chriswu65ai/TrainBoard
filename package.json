{
  "name": "trainboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.0",
    "@mui/material": "^6.3.0",
    "@mui/styles": "^6.3.0",
    "date-fns": "^2.29.3",
    "date-fns-tz": "^2.0.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "prettier": "^3.6.2",
    "protobufjs": "^7.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.10.0",
    "use-debounce": "^9.0.4"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.24.0",
    "@types/node": "^22.18.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-unused-imports": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "sass": "^1.61.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-svgr": "^4.5.0"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "gen:openapi": "openapi-generator-cli generate -g typescript-fetch -c openapitools.json -i tripplanner_v1_swag_efa11_20251002.yml -o src/models/TripPlanner",
    "gen:pb": "npm run gen:pbjs && npm run gen:pbts",
    "gen:pbjs": "pbjs -t static-module -w es6 -o src/gen/proto.js src/proto/gtfs-realtime-trains.proto",
    "gen:pbts": "pbts -o src/gen/proto.d.ts src/gen/proto.js",
    "lint": "npm run lint:eslint && npm run typecheck",
    "lint:eslint": "eslint --ext .ts,.tsx src",
    "lint:fix": "npm run lint:eslint -- --fix",
    "typecheck": "tsc --noEmit",
    "tunnel": "ngrok http 3000",
    "prepare": "husky"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
